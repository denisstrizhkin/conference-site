{% extends "base.jinja" %}
{% block title %}{{ title }}{% endblock %}
{% block main %}
    <h4 class="mb-3 text-center">Регистрационная форма:</h4>
    <div class="d-flex justify-content-center">
        <div class="col-md-8">
            {% if error %}<div class="alert alert-danger" role="alert">{{ error }}</div>{% endif %}
            {% if message %}<div class="alert alert-success" role="alert">{{ message }}</div>{% endif %}
            <form action="/user/{{ user.id }}"
                  enctype="multipart/form-data"
                  method="post">
                <div class="mb-3">
                    <label class="form-label">
                        Логин
                        <input type="login"
                               class="form-control"
                               name="email"
                               value="{{ user.email|default('', true) }}"
                               required>
                    </label>
                </div>
                <div class="row g-3">
                    <div class="col-sm-4">
                        <label class="form-label">
                            Фамилия
                            <input type="text"
                                   class="form-control"
                                   name="surname"
                                   value="{{ user.surname|default('', true) }}"
                                   required>
                        </label>
                        <div class="invalid-feedback">Это поле необходимо заполнить</div>
                    </div>
                    <div class="col-sm-4">
                        <label class="form-label">
                            Имя
                            <input type="text"
                                   class="form-control"
                                   name="name"
                                   value="{{ user.name|default('', true) }}"
                                   required>
                        </label>
                        <div class="invalid-feedback">Это поле необходимо заполнить</div>
                    </div>
                    <div class="col-sm-4">
                        <label class="form-label">
                            Отчество (если есть)
                            <input type="text"
                                   class="form-control"
                                   name="patronymic"
                                   value="{{ user.patronymic|default('', true) }}">
                        </label>
                    </div>
                    <div class="col-12">
                        <label class="form-label">
                            Организация (краткое название университета/школы)
                            <input type="text"
                                   class="form-control"
                                   name="organization"
                                   value="{{ user.organization|default('', true) }}"
                                   required>
                        </label>
                        <div class="invalid-feedback">Это поле необходимо заполнить</div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">
                            Курс (класс)
                            <input type="number"
                                   class="form-control"
                                   name="year"
                                   value="{{ user.year|default('', true) }}"
                                   required>
                        </label>
                        <div class="invalid-feedback">Это поле необходимо заполнить</div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">
                            Telegram-id (предпочтительно) или адрес электронной почты
                            <input type="text"
                                   class="form-control"
                                   name="contact"
                                   value="{{ user.contact|default('', true) }}"
                                   required>
                        </label>
                        <div class="invalid-feedback">Это поле необходимо заполнить</div>
                    </div>
                </div>
                <hr class="my-5">
                <p class="fs-6 mb-3 mt-4">
                    <strong>Формат участия:</strong>
                </p>
                <select class="form-select mb-5" name="role" id="selectedRole">
                    {% for role in roles %}
                        {% if user.role == role[0] %}
                            <option value="{{ role[0] }}" selected>{{ role[1] }}</option>
                        {% else %}
                            <option value="{{ role[0] }}">{{ role[1] }}</option>
                        {% endif %}
                    {% endfor %}
                </select>
                {% if user.role == "admin" %}
                    <a class="btn btn-primary" href="/user/">Список участников</a>
                    <a class="btn btn-primary" href="/vote/admin">Голосование</a>
                {% endif %}
                <div id="reportFormParent">
                    <fieldset id="reportFields" class="border-0 p-0 m-0">
                        <p class="fs-6 mb-3 mt-4">
                            <strong>Тип доклада:</strong>
                        </p>
                        <select class="form-select mb-5" name="form_type" id="selectedFormType">
                            <option value="classical"
                                    {% if not user.form or user.form.form_type == "classical" %}selected{% endif %}>
                                Классический
                            </option>
                            <option value="nonlinear"
                                    {% if user.form and user.form.form_type == "nonlinear" %}selected{% endif %}>
                                Нелинейный
                            </option>
                        </select>
                        <fieldset id="classicalFields" class="border-0 p-0 m-0">
                            <div class="col-12">
                                <label class="form-label">
                                    <strong>Название доклада:</strong>
                                    <input type="text"
                                           class="form-control"
                                           name="report_name"
                                           id="reportNameInput"
                                           value="{{ user.form.report_name|default('', true) }}"
                                           required>
                                </label>
                                <div class="invalid-feedback">Это поле необходимо заполнить</div>
                            </div>
                        </fieldset>
                        <fieldset id="nonlinearFields" class="border-0 p-0 m-0">
                            <div class="col-12">
                                <label class="form-label">
                                    <strong>Где делаешь науку:</strong>
                                    <input type="text"
                                           class="form-control"
                                           name="work_place"
                                           id="workPlaceInput"
                                           value="{{ user.form.work_place|default('', true) }}">
                                </label>
                                <div class="invalid-feedback">Это поле необходимо заполнить</div>
                            </div>
                            <div class="col-12 mt-3">
                                <label class="form-label">
                                    <strong>Научный руководитель:</strong>
                                    <input type="text"
                                           class="form-control"
                                           name="supervisor"
                                           id="supervisorInput"
                                           value="{{ user.form.supervisor|default('', true) }}">
                                </label>
                                <div class="invalid-feedback">Это поле необходимо заполнить</div>
                            </div>
                            <div class="col-12 mt-3">
                                <label class="form-label">
                                    <strong>Предполагаемая тема (не финальная):</strong>
                                    <input type="text"
                                           class="form-control"
                                           name="expected_topic"
                                           id="expectedTopicInput"
                                           value="{{ user.form.expected_topic|default('', true) }}">
                                </label>
                                <div class="invalid-feedback">Это поле необходимо заполнить</div>
                            </div>
                        </fieldset>
                        <p class="fs-6 mb-3 mt-4">
                            <strong>Область научного знания, к которой относится тема Вашего доклада:</strong>
                        </p>
                        <div class="form-group">
                            <div class="form-check border border-2 rounded">
                                <label class="form-check-label p-2">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="flag_bio_phys"
                                           {% if user.form.flag_bio_phys %}checked{% endif %}>
                                    Биофизика/биотехнологии
                                </label>
                            </div>
                            <div class="form-check border border-2 rounded">
                                <label class="form-check-label p-2">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="flag_comp_sci"
                                           {% if user.form.flag_comp_sci %}checked{% endif %}>
                                    Компьютерные науки (в т.ч. биоинформатика)
                                </label>
                            </div>
                            <div class="form-check border border-2 rounded">
                                <label class="form-check-label p-2">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="flag_math_phys"
                                           {% if user.form.flag_math_phys %}checked{% endif %}>
                                    Матем. физика (+ теор. вер., теория групп и т.п.)
                                </label>
                            </div>
                            <div class="form-check border border-2 rounded">
                                <label class="form-check-label p-2">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="flag_med_phys"
                                           {% if user.form.flag_med_phys %}checked{% endif %}>
                                    Медицинская физика
                                </label>
                            </div>
                            <div class="form-check border border-2 rounded">
                                <label class="form-check-label p-2">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="flag_nano_tech"
                                           {% if user.form.flag_nano_tech %}checked{% endif %}>
                                    Нанотехнологии
                                </label>
                            </div>
                            <div class="form-check border border-2 rounded">
                                <label class="form-check-label p-2">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="flag_general_phys"
                                           {% if user.form.flag_general_phys %}checked{% endif %}>
                                    Сюжеты общей физики (1-2 курс)
                                </label>
                            </div>
                            <div class="form-check border border-2 rounded">
                                <label class="form-check-label p-2">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="flag_solid_body"
                                           {% if user.form.flag_solid_body %}checked{% endif %}>
                                    Теор. физика твердых тел
                                </label>
                            </div>
                            <div class="form-check border border-2 rounded">
                                <label class="form-check-label p-2">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="flag_space_phys"
                                           {% if user.form.flag_space_phys %}checked{% endif %}>
                                    Физика космоса
                                </label>
                            </div>
                        </div>
                        <fieldset id="classicalRadio" class="border-0 p-0 m-0">
                            <p class="fs-6 mb-3 mt-4">
                                <strong>Ваш доклад оригинальный или научно-популярный?</strong>
                            </p>
                            <div class="form-check border border-2 rounded">
                                <label class="form-check-label p-2">
                                    <input class="form-check-input"
                                           type="radio"
                                           name="report_type"
                                           value="original"
                                           {% if user.form.report_type == "original" %}checked{% endif %}>
                                    Оригинальный, собственное исследование (с научной новизной)
                                </label>
                            </div>
                            <div class="form-check border border-2 rounded">
                                <label class="form-check-label p-2">
                                    <input class="form-check-input"
                                           type="radio"
                                           name="report_type"
                                           value="scipop"
                                           {% if user.form.report_type == "scipop" %}checked{% endif %}>
                                    Научно-популярный, интересный сюжет/эффект/устройство
                                </label>
                            </div>
                        </fieldset>
                        <p class="fs-6 mt-4">
                            <strong>Файл с OnePager (опционально для нелинейного доклада):</strong>
                        </p>
                        <p class="fs-6 pb-2">
                            Ваш OnePager, оформленный в соответствии с
                            <a href="/static/appl_templates/abstract.docx">шаблоном</a>.
                        </p>
                        <div class="mt-4">
                            <label class="form-label">
                                <input class="d-none"
                                       id="reportFileInput"
                                       type="file"
                                       name="report_file"
                                       accept=".docx,.tex">
                                <!-- Custom styled button -->
                                <button class="btn btn-success"
                                        type="button"
                                        onclick="document.getElementById('reportFileInput').click()">Выбрать</button>
                                <!-- Display area for filename -->
                                <span id="reportFileName">
                                    {% if report_file %}
                                        {{ report_file.name }}
                                    {% else %}
                                        Файл не выбран
                                    {% endif %}
                                </span>
                            </label>
                            <div class="invalid-feedback">Неаобходимо выбрать файл!</div>
                        </div>
                        {% if report_file %}
                            <a href="/files/{{ report_file.id }}"
                               class="btn btn-primary mt-1"
                               download>Скачать</a>
                        {% endif %}
                    </fieldset>
                </div>
                <hr class="my-5">
                <div class="d-flex justify-content-center mt-3">
                    <button class="btn btn-success btn-lg" type="submit">Сохранить</button>
                </div>
            </form>
        </div>
    </div>
    {% if current_user.id == user.id %}
        <div class="d-flex justify-content-center mt-3">
            <div class="col-md-8 text-center">
                <form action="/auth/logout" method="post" class="d-inline">
                    <button type="submit" class="btn btn-danger btn-lg">
                        <i class="bi bi-box-arrow-right"></i> Выйти
                    </button>
                </form>
            </div>
        </div>
    {% elif current_user.role == "admin" and user.role != "admin" %}
        <div class="d-flex justify-content-center mt-3">
            <div class="col-md-8 text-center">
                <form action="/user/{{ user.id }}/delete"
                      method="post"
                      onsubmit="return confirm('Вы уверены, что хотите удалить этого пользователя?');">
                    <button type="submit" class="btn btn-outline-danger btn-lg">
                        <i class="bi bi-trash"></i> Удалить пользователя
                    </button>
                </form>
            </div>
        </div>
    {% endif %}
    <script>
"use strict";

function initUpdateFormType() {
    const selectedFormType = document.getElementById("selectedFormType");
    const classicalFields = document.getElementById("classicalFields");
    const classicalRadio = document.getElementById("classicalRadio");
    const nonlinearFields = document.getElementById("nonlinearFields");
    const sync = () => {
        const isClassical = selectedFormType.value === "classical";
        classicalFields.disabled = !isClassical;
        classicalFields.hidden = !isClassical;
        classicalRadio.disabled = !isClassical;
        classicalRadio.hidden = !isClassical;
        nonlinearFields.disabled = isClassical;
        nonlinearFields.hidden = isClassical;
    };
    selectedFormType.addEventListener("change", sync);
    sync();
}

function initUpdateForm() {
    const selectedRole = document.getElementById("selectedRole");
    const reportFields = document.getElementById("reportFields");
    const sync = () => {
        const isParticipant = selectedRole.value === "participant";
        reportFields.disabled = !isParticipant;
        reportFields.hidden = !isParticipant;
    };
    selectedRole.addEventListener("change", sync);
    sync();
    initUpdateFormType();
}

function initUpdateFile() {
    const reportFileInput = document.getElementById("reportFileInput");
    const reportFileName = document.getElementById("reportFileName");
    const sync = () => {
        const fileName = reportFileInput.files[0]?.name ?? "No file chosen";
        reportFileName.textContent = fileName;
    };
    reportFileInput.addEventListener("change", sync);
}

document.addEventListener("DOMContentLoaded", function () {
    initUpdateForm();
    initUpdateFile();
});
    </script>
{% endblock %}
