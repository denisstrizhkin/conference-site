{% extends "base.jinja" %}
{% block main %}
    {% if message %}<div class="alert alert-success" role="alert">{{ message }}</div>{% endif %}
    {% if error %}<div class="alert alert-danger" role="alert">{{ error }}</div>{% endif %}
    <a class="btn btn-primary" href="/user/excel/">Скачать таблицу</a>
    <div class="table-responsive-lg mw-100">
        <table class="table table-hover align-middle text-center">
            <thead>
                <tr>
                    <th scope="col">Логин</th>
                    <th scope="col">Фамилия</th>
                    <th scope="col">Имя</th>
                    <th scope="col">Формат</th>
                    <th scope="col" class="rep-name-col">Название доклада</th>
                    <th scope="col">Файл с тезисом</th>
                    <th scope="col">Действия</th>
                </tr>
            </thead>
            <tbody class="table-group-divider">
                {% for user in users %}
                    <tr>
                        <th scope="raw">
                            <a href="/user/{{ user.id }}">{{ user.email }}</a>
                        </th>
                        <td>{{ user.surname|default('---', true) }}</td>
                        <td>{{ user.name|default('---', true) }}</td>
                        <td>
                            {% if user.role == "participant" %}
                                Участник
                            {% elif user.role == "viewer" %}
                                Зритель
                            {% elif user.role == "admin" %}
                                Админ
                            {% elif user.role == "basic" %}
                                Не участвует
                            {% endif %}
                        </td>
                        <td class="text-wrap text-break rep-name-col">
                            {% if user.form %}
                                {% if user.form.form_type == "nonlinear" %}
                                    {{ user.form.expected_topic|default('---', true) }}
                                {% else %}
                                    {{ user.form.report_name|default('---', true) }}
                                {% endif %}
                            {% else %}
                                ---
                            {% endif %}
                        </td>
                        <td>
                            {% if user.form.file_id %}
                                <a href="/files/{{ user.form.file_id }}">Скачать</a>
                            {% else %}
                                <p class="fs-6">---</p>
                            {% endif %}
                        </td>
                        <td>
                            {% if user.role != "admin" %}
                                <form action="/user/{{ user.id }}/delete" method="post" onsubmit="return confirm('Вы уверены, что хотите удалить этого пользователя?');">
                                    <button type="submit" class="btn btn-danger btn-sm">Удалить</button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
